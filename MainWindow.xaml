<Window x:Class="DesktopToDo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="极简透明桌面待办清单"
        Height="600" Width="500"
        x:Name="MainWindowRoot"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- 任务卡片样式 -->
        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#55FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 已完成任务卡片样式 -->
        <Style x:Key="CompletedCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderBrush" Value="#15FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 操作按钮样式 -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="6"
                                Padding="0" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 顶部按钮样式 -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#44FFFFFF" CornerRadius="8"
                                Padding="10,0" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次级清单 CheckBox 样式 -->
        <Style x:Key="SubTaskCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="3"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#CC90EE90" CornerRadius="12" Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 -->
            <Border Grid.Row="0" Background="#30FFFFFF" CornerRadius="8" Padding="10,8" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="极简待办" FontSize="17" FontWeight="Bold" Foreground="#2D3436" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnAdd" Content="➕ 添加" Style="{StaticResource HeaderButtonStyle}" Margin="0,0,6,0" Click="BtnAdd_Click"/>
                        <Button x:Name="BtnSettings" Content="⚙️" Style="{StaticResource HeaderButtonStyle}" Margin="0,0,6,0" Click="BtnSettings_Click" Width="32" Padding="0"/>
                        <Button x:Name="BtnMinimize" Content="—" FontSize="16" FontWeight="Bold" Style="{StaticResource HeaderButtonStyle}" Margin="0,0,4,0" Click="BtnMinimize_Click" Width="32" Padding="0" Foreground="#636E72"/>
                        <Button x:Name="BtnClose" Content="✕" FontSize="14" FontWeight="Bold" Style="{StaticResource HeaderButtonStyle}" Click="BtnClose_Click" Width="32" Padding="0" Foreground="#636E72"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0" x:Name="CompletedColumn"/>
                </Grid.ColumnDefinitions>

                <!-- 待办事项 -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,8">
                        <TextBlock Text="待办事项" FontSize="13" FontWeight="SemiBold" Foreground="#636E72" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PendingCount" Text="" FontSize="11" Foreground="#B2BEC3" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                        <ItemsControl x:Name="PendingTasksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 任务卡片 -->
                                    <Border Style="{StaticResource TaskCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 左侧：标签 + 优先级 -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding RepeatShortLabel}" FontSize="10" FontWeight="Bold" Foreground="{Binding RepeatColor}" VerticalAlignment="Center" Margin="0,0,5,0" Visibility="{Binding HasRepeat, Converter={StaticResource BoolToVisConverter}}"/>
                                                <Border Width="8" Height="8" CornerRadius="4" Background="{Binding PriorityColor}" ToolTip="{Binding PriorityText}" VerticalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- 中间：内容 + 次级清单 + 提醒时间 -->
                                            <StackPanel Grid.Column="1">
                                                <!-- 主任务内容（可点击展开/折叠） -->
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- 展开/折叠按钮 -->
                                                    <Button Content="{Binding ExpandButtonText}" 
                                                            Visibility="{Binding HasSubTasks, Converter={StaticResource BoolToVisConverter}}"
                                                            Click="ToggleSubTasks_Click"
                                                            Tag="{Binding}"
                                                            Width="20" Height="20"
                                                            FontSize="10"
                                                            Foreground="#74B9FF"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            Margin="-4,0,2,0"
                                                            VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#2D3436" FontSize="14" FontWeight="Medium" Cursor="Hand" MouseLeftButtonDown="TaskContent_MouseLeftButtonDown">
                                                        <TextBlock.Tag>
                                                            <Binding/>
                                                        </TextBlock.Tag>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- 次级清单区域 -->
                                                <ItemsControl ItemsSource="{Binding SubTasks}" Margin="20,6,0,0" Visibility="{Binding SubTasksVisibility}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Style="{StaticResource SubTaskCheckBoxStyle}"
                                                                      IsChecked="{Binding IsChecked}"
                                                                      Click="SubTaskCheck_Click"
                                                                      Tag="{Binding}">
                                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12" Foreground="#636E72">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                                    <Setter Property="Foreground" Value="#B2BEC3"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- 次级清单进度 + 提醒时间 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <!-- 进度指示 -->
                                                    <TextBlock Visibility="{Binding HasSubTasks, Converter={StaticResource BoolToVisConverter}}"
                                                               FontSize="10" Foreground="#74B9FF" Margin="0,0,8,0" VerticalAlignment="Center"
                                                               Text="{Binding SubTaskProgressText, Mode=OneWay}"/>
                                                    <!-- 提醒时间 -->
                                                    <TextBlock Text="{Binding RemindTimeText}" FontSize="10" Foreground="#B2BEC3" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- 右侧：操作按钮 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="4,0,0,0">
                                                <Button Content="✏️" Style="{StaticResource ActionButtonStyle}" Click="BtnEdit_Click" Tag="{Binding}" ToolTip="编辑"/>
                                                <Button Content="✓" Style="{StaticResource ActionButtonStyle}" Click="BtnComplete_Click" Tag="{Binding}" ToolTip="完成" Foreground="#00B894" FontWeight="Bold"/>
                                                <Button Content="🗑️" Style="{StaticResource ActionButtonStyle}" Click="BtnDelete_Click" Tag="{Binding}" ToolTip="删除"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <!-- 展开/收起按钮 -->
                <Button Grid.Column="1"
                        x:Name="ToggleButton"
                        Width="28"
                        Background="Transparent"
                        Click="ToggleButton_Click"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Cursor="Hand"
                        MouseEnter="ToggleButton_MouseEnter"
                        MouseLeave="ToggleButton_MouseLeave">
                    <Border x:Name="ToggleButtonBorder" Background="Transparent" CornerRadius="6" Padding="4">
                        <TextBlock x:Name="ToggleText"
                                   Text="»"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#B2BEC3"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- 已完成区域 -->
                <StackPanel Grid.Column="2" x:Name="CompletedPanel" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="7,0,0,8">
                        <TextBlock Text="✅ 已完成" FontSize="13" FontWeight="SemiBold" Foreground="#636E72" VerticalAlignment="Center"/>
                        <Button x:Name="BtnClearCompleted" Content="清空" Width="50" Height="24" FontSize="11"
                                Margin="10,0,0,0" Click="BtnClearCompleted_Click"
                                Cursor="Hand" Foreground="#B2BEC3"
                                Style="{StaticResource HeaderButtonStyle}"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500" Margin="7,0,0,0">
                        <ItemsControl x:Name="CompletedTasksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CompletedCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#B2BEC3" TextDecorations="Strikethrough" FontSize="13"/>

                                                <!-- 已完成任务的次级清单 -->
                                                <ItemsControl ItemsSource="{Binding SubTasks}" Margin="4,4,0,0" Visibility="{Binding HasSubTasks, Converter={StaticResource BoolToVisConverter}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                                                <TextBlock Text="✓" FontSize="11" Foreground="#00B894" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="11" Foreground="#B2BEC3" TextDecorations="Strikethrough"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding CompletedTimeText}" FontSize="10" Foreground="#DFE6E9" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Button Content="🗑️" Style="{StaticResource ActionButtonStyle}" Grid.Column="1" Click="BtnDeleteCompleted_Click" Tag="{Binding}" ToolTip="删除" Opacity="0.6"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
