<Window x:Class="DesktopToDo.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑任务" Height="680" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="任务内容" FontWeight="SemiBold" FontSize="14" Foreground="#333333" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="0" Text="第一行为主任务，回车后输入的内容将自动成为次级清单" FontSize="11" Foreground="#999999" Margin="0,18,0,8"/>
        <TextBox x:Name="TxtContent" Grid.Row="1" Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" FontSize="14" Padding="10"
                 BorderBrush="#E0E0E0" BorderThickness="1"
                 Background="#FAFAFA" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <CheckBox x:Name="ChkHasRemind" Content="设置提醒" 
                      Checked="ChkHasRemind_Changed" Unchecked="ChkHasRemind_Changed" 
                      VerticalAlignment="Center" FontSize="14" Foreground="#333333"/>
        </StackPanel>

        <Grid Grid.Row="3" Name="ReminderPanel" Visibility="Collapsed" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="DpRemindDate" Width="160" FontSize="14" Padding="8" 
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Background="#FAFAFA" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtRemindTime" Width="100" Grid.Column="2" FontSize="14" Padding="8"
                     VerticalContentAlignment="Center" BorderBrush="#E0E0E0" BorderThickness="1" 
                     Background="#FAFAFA" Text="09:00"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="重要等级" FontSize="14" Foreground="#333333" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbPriority" Grid.Column="2" Width="100" FontSize="14" Padding="8,4"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                <ComboBoxItem Content="低" Tag="0"/>
                <ComboBoxItem Content="普通" Tag="1" IsSelected="True"/>
                <ComboBoxItem Content="高" Tag="2"/>
                <ComboBoxItem Content="紧急" Tag="3"/>
            </ComboBox>
        </Grid>

        <TextBlock Grid.Row="5" Text="重复规则" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,12"/>
        
        <Grid Grid.Row="6" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CmbRepeat" Width="140" FontSize="14" Padding="8,4"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA"
                      SelectionChanged="CmbRepeat_SelectionChanged">
                <ComboBoxItem Content="不重复" Tag="0" IsSelected="True"/>
                <ComboBoxItem Content="每天" Tag="1"/>
                <ComboBoxItem Content="每周" Tag="2"/>
                <ComboBoxItem Content="每月" Tag="3"/>
                <ComboBoxItem Content="每季度" Tag="4"/>
                <ComboBoxItem Content="每年" Tag="5"/>
                <ComboBoxItem Content="工作日" Tag="6"/>
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="7" Name="DailyPanel" Visibility="Collapsed" Margin="0,0,0,12" Orientation="Horizontal">
            <TextBlock Text="每" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtDailyInterval" Width="60" Text="1" Margin="8,0,8,0" FontSize="13" Padding="6,4"
                     VerticalContentAlignment="Center" BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA"/>
            <TextBlock Text="天" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Name="WeeklyPanel" Visibility="Collapsed" Margin="0,0,0,12">
            <TextBlock Text="选择星期" FontSize="13" Foreground="#666666" Margin="0,0,0,8"/>
            <WrapPanel>
                <CheckBox x:Name="ChkMon" Content="周一" Tag="1" Margin="0,0,12,6" FontSize="13"/>
                <CheckBox x:Name="ChkTue" Content="周二" Tag="2" Margin="0,0,12,6" FontSize="13"/>
                <CheckBox x:Name="ChkWed" Content="周三" Tag="3" Margin="0,0,12,6" FontSize="13"/>
                <CheckBox x:Name="ChkThu" Content="周四" Tag="4" Margin="0,0,12,6" FontSize="13"/>
                <CheckBox x:Name="ChkFri" Content="周五" Tag="5" Margin="0,0,12,6" FontSize="13"/>
                <CheckBox x:Name="ChkSat" Content="周六" Tag="6" Margin="0,0,12,6" FontSize="13"/>
                <CheckBox x:Name="ChkSun" Content="周日" Tag="0" Margin="0,0,12,6" FontSize="13"/>
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Row="7" Name="MonthlyPanel" Visibility="Collapsed" Margin="0,0,0,12">
            <RadioButton x:Name="RbMonthlyDay" Margin="0,0,0,8" FontSize="13" Checked="RbMonthly_Checked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="每月" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbMonthlyDay" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                              BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA"/>
                    <TextBlock Text="日" FontSize="13" Foreground="#666666" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="RbMonthlyWeek" Margin="0,0,0,8" FontSize="13" Checked="RbMonthly_Checked">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="每月" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbMonthlyWeekNum" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                              BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                        <ComboBoxItem Content="第一个" Tag="1" IsSelected="True"/>
                        <ComboBoxItem Content="第二个" Tag="2"/>
                        <ComboBoxItem Content="第三个" Tag="3"/>
                        <ComboBoxItem Content="第四个" Tag="4"/>
                        <ComboBoxItem Content="最后一个" Tag="5"/>
                    </ComboBox>
                    <ComboBox x:Name="CmbMonthlyWeekDay" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                              BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                        <ComboBoxItem Content="周一" Tag="1" IsSelected="True"/>
                        <ComboBoxItem Content="周二" Tag="2"/>
                        <ComboBoxItem Content="周三" Tag="3"/>
                        <ComboBoxItem Content="周四" Tag="4"/>
                        <ComboBoxItem Content="周五" Tag="5"/>
                        <ComboBoxItem Content="周六" Tag="6"/>
                        <ComboBoxItem Content="周日" Tag="0"/>
                    </ComboBox>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="RbMonthlyLastDay" Content="每月最后一天" FontSize="13" Checked="RbMonthly_Checked"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Name="QuarterlyPanel" Visibility="Collapsed" Margin="0,0,0,12" Orientation="Horizontal">
            <TextBlock Text="每季度" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbQuarterlyMonth" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                <ComboBoxItem Content="第1月" Tag="1" IsSelected="True"/>
                <ComboBoxItem Content="第2月" Tag="2"/>
                <ComboBoxItem Content="第3月" Tag="3"/>
            </ComboBox>
            <ComboBox x:Name="CmbQuarterlyDay" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Name="YearlyPanel" Visibility="Collapsed" Margin="0,0,0,12" Orientation="Horizontal">
            <TextBlock Text="每年" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
            <ComboBox x:Name="CmbYearlyMonth" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA">
                <ComboBoxItem Content="1月" Tag="1" IsSelected="True"/>
                <ComboBoxItem Content="2月" Tag="2"/>
                <ComboBoxItem Content="3月" Tag="3"/>
                <ComboBoxItem Content="4月" Tag="4"/>
                <ComboBoxItem Content="5月" Tag="5"/>
                <ComboBoxItem Content="6月" Tag="6"/>
                <ComboBoxItem Content="7月" Tag="7"/>
                <ComboBoxItem Content="8月" Tag="8"/>
                <ComboBoxItem Content="9月" Tag="9"/>
                <ComboBoxItem Content="10月" Tag="10"/>
                <ComboBoxItem Content="11月" Tag="11"/>
                <ComboBoxItem Content="12月" Tag="12"/>
            </ComboBox>
            <ComboBox x:Name="CmbYearlyDay" Width="70" Margin="8,0,0,0" FontSize="13" Padding="6,4"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA"/>
        </StackPanel>

        <TextBlock Grid.Row="8" Text="结束条件" FontSize="14" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,12"/>

        <Grid Grid.Row="9" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <RadioButton x:Name="RbNeverEnd" Content="永不结束" IsChecked="True" 
                      Margin="0,0,0,6" FontSize="13"/>
            <RadioButton x:Name="RbEndAfter" Content="结束于" Margin="0,0,0,6" Grid.Column="2" FontSize="13"
                      Checked="RbEnd_Checked" Unchecked="RbEnd_Unchecked"/>
            <TextBox x:Name="TxtEndAfterCount" Width="60" Grid.Column="4" Text="10" FontSize="13" Padding="6,4"
                     VerticalContentAlignment="Center" BorderBrush="#E0E0E0" BorderThickness="1" 
                     Background="#FAFAFA" IsEnabled="False"/>
            <TextBlock Text="次" Grid.Column="5" FontSize="13" Foreground="#666666" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="10" Margin="0,0,0,24" Name="EndDateGrid">
            <RadioButton x:Name="RbEndOnDate" Content="结束于日期" Margin="0,0,0,6" FontSize="13"
                      Checked="RbEnd_Checked" Unchecked="RbEnd_Unchecked"/>
            <DatePicker x:Name="DpEndDate" Width="180" FontSize="14" Padding="8" Margin="20,20,0,0"
                      BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA" IsEnabled="False"/>
        </Grid>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancel" Content="取消" Width="90" Height="36" Margin="0,0,12,0" 
                      Click="BtnCancel_Click" FontSize="14"
                      Background="#F5F5F5" Foreground="#666666" BorderBrush="#E0E0E0" BorderThickness="1"
                      MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"/>
            <Button x:Name="BtnOK" Content="确定" Width="90" Height="36" 
                      Click="BtnOK_Click" FontSize="14"
                      Background="#007AFF" Foreground="White" BorderBrush="#007AFF" BorderThickness="1"
                      MouseEnter="BtnOK_MouseEnter" MouseLeave="BtnOK_MouseLeave"/>
        </StackPanel>
    </Grid>
</Window>
