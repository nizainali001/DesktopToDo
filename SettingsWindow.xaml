<Window x:Class="DesktopToDo.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选项卡 -->
        <TabControl Grid.Row="0" BorderThickness="0" Background="Transparent">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Height" Value="36"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,2"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#3B82F6"/>
                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="#666666"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#E8E8E8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- 选项卡1：主题设置 -->
            <TabItem Header="主题设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel Background="White" Margin="0">
                        <!-- 背景透明度 -->
                        <TextBlock Text="背景透明度：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Slider x:Name="SliderBgOpacity" Minimum="0.1" Maximum="1.0" Value="0.8" 
                                    Width="220" TickFrequency="0.1" IsSnapToTickEnabled="True" 
                                    ValueChanged="SliderBgOpacity_ValueChanged"/>
                            <TextBlock x:Name="TxtBgOpacityValue" Text="80%" Width="50" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                        </StackPanel>

                        <!-- 文字透明度 -->
                        <TextBlock Text="文字透明度：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Slider x:Name="SliderTextOpacity" Minimum="0.3" Maximum="1.0" Value="1.0" 
                                    Width="220" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderTextOpacity_ValueChanged"/>
                            <TextBlock x:Name="TxtTextOpacityValue" Text="100%" Width="50" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                        </StackPanel>

                        <!-- 字体大小 -->
                        <TextBlock Text="字体大小：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Slider x:Name="SliderFontSize" Minimum="10" Maximum="24" Value="14" 
                                    Width="220" TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderFontSize_ValueChanged"/>
                            <TextBlock x:Name="TxtFontSizeValue" Text="14" Width="50" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"/>
                        </StackPanel>

                        <!-- 字体颜色 -->
                        <TextBlock Text="字体颜色：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBox x:Name="TxtTextColor" Width="100" Text="#F1F5F9" VerticalContentAlignment="Center" 
                                     BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA" Margin="0,0,10,0"
                                     TextChanged="TxtTextColor_TextChanged"/>
                            <Border x:Name="TextColorPreview" Width="28" Height="28" Background="#F1F5F9" 
                                    BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Margin="0,0,10,0"/>
                            <TextBlock Text="格式：#RRGGBB" FontSize="11" Foreground="#999999" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 主题颜色 -->
                        <TextBlock Text="主题颜色：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,16">
                            <WrapPanel Margin="0,0,0,10">
                                <RadioButton x:Name="RbLightGreen" Content="淡绿色" GroupName="ThemeColor" IsChecked="True" Margin="0,0,16,8" Foreground="#333333"/>
                                <RadioButton x:Name="RbWhite" Content="白色" GroupName="ThemeColor" Margin="0,0,16,8" Foreground="#333333"/>
                                <RadioButton x:Name="RbGray" Content="灰色" GroupName="ThemeColor" Margin="0,0,16,8" Foreground="#333333"/>
                                <RadioButton x:Name="RbDark" Content="深色" GroupName="ThemeColor" Margin="0,0,16,8" Foreground="#333333"/>
                                <RadioButton x:Name="RbCustom" Content="自定义" GroupName="ThemeColor" Checked="RbCustom_Checked" Unchecked="RbCustom_Unchecked" Foreground="#333333"/>
                            </WrapPanel>
                            <StackPanel x:Name="CustomColorPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,0">
                                <TextBlock Text="R: " VerticalAlignment="Center" Foreground="#333333"/>
                                <TextBox x:Name="TxtR" Width="50" Text="144" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="G: " VerticalAlignment="Center" Foreground="#333333"/>
                                <TextBox x:Name="TxtG" Width="50" Text="238" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="B: " VerticalAlignment="Center" Foreground="#333333"/>
                                <TextBox x:Name="TxtB" Width="50" Text="144" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 序号圆点颜色 -->
                        <TextBlock Text="序号圆点颜色（循环）：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="颜色1" FontSize="12" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtNumberColor1" Grid.Row="0" Grid.Column="1" Text="#90EE90" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="颜色2" FontSize="12" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtNumberColor2" Grid.Row="1" Grid.Column="1" Text="#87CEEB" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="颜色3" FontSize="12" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtNumberColor3" Grid.Row="2" Grid.Column="1" Text="#FBBF24" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="颜色4" FontSize="12" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtNumberColor4" Grid.Row="3" Grid.Column="1" Text="#FF6B6B" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="颜色5" FontSize="12" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtNumberColor5" Grid.Row="4" Grid.Column="1" Text="#DDA0DD" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="颜色6" FontSize="12" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtNumberColor6" Grid.Row="5" Grid.Column="1" Text="#FFB6C1" VerticalContentAlignment="Center" Margin="0,2"/>
                        </Grid>
                        <TextBlock Text="默认：浅绿、浅蓝、黄、浅红、浅紫、粉" FontSize="10" Foreground="#999999" Margin="0,0,0,16"/>

                        <!-- 重复类型颜色 -->
                        <TextBlock Text="重复类型颜色：" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="每天" FontSize="12" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtDailyColor" Grid.Row="0" Grid.Column="1" Text="#00FF00" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="每周" FontSize="12" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtWeeklyColor" Grid.Row="1" Grid.Column="1" Text="#00FF00" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="每月" FontSize="12" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtMonthlyColor" Grid.Row="2" Grid.Column="1" Text="#FF0000" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="每季度" FontSize="12" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtQuarterlyColor" Grid.Row="3" Grid.Column="1" Text="#FF0000" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="每年" FontSize="12" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtYearlyColor" Grid.Row="4" Grid.Column="1" Text="#000000" VerticalContentAlignment="Center" Margin="0,2"/>
                            <TextBlock Text="工作日" FontSize="12" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" Foreground="#333333"/>
                            <TextBox x:Name="TxtWorkdaysColor" Grid.Row="5" Grid.Column="1" Text="#00FF00" VerticalContentAlignment="Center" Margin="0,2"/>
                        </Grid>
                        <TextBlock Text="格式：#RRGGBB，如 #FF0000 为红色" FontSize="10" Foreground="#999999" Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 选项卡2：数据管理 -->
            <TabItem Header="数据管理">
                <StackPanel Background="White" Margin="0,8,0,0">
                    <TextBlock Text="数据导入/导出" FontWeight="SemiBold" FontSize="14" Foreground="#333333" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="导出任务" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                    <TextBlock Text="将所有任务导出为 JSON 文件备份" FontSize="11" Foreground="#999999" Margin="0,0,0,10"/>
                    <Button x:Name="BtnExport" Content="📤 导出任务" Width="120" Height="32" Margin="0,0,0,20" Click="BtnExport_Click"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    
                    <Separator Margin="0,0,0,20"/>
                    
                    <TextBlock Text="导入任务" FontSize="12" Foreground="#666666" Margin="0,0,0,6"/>
                    <TextBlock Text="从 JSON 文件导入任务，可选择合并或替换现有任务" FontSize="11" Foreground="#999999" Margin="0,0,0,10"/>
                    <Button x:Name="BtnImport" Content="📥 导入任务" Width="120" Height="32" Click="BtnImport_Click"
                            Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </TabItem>

            <!-- 选项卡3：其他设置 -->
            <TabItem Header="其他设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel Background="White" Margin="0">
                        <TextBlock Text="提醒设置" FontWeight="SemiBold" FontSize="14" Foreground="#333333" Margin="0,0,0,12"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="提前提醒分钟数：" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Width="110"/>
                            <TextBox x:Name="TxtAdvanceMinutes" Width="60" Text="5" VerticalContentAlignment="Center" 
                                     BorderBrush="#E0E0E0" BorderThickness="1" Background="#FAFAFA"/>
                            <TextBlock Text="分钟" FontSize="12" Foreground="#666666" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>

                        <Separator Margin="0,0,0,16"/>

                        <TextBlock Text="显示设置" FontWeight="SemiBold" FontSize="14" Foreground="#333333" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ChkShowCreatedTime" Content="选中任务后显示创建时间" Margin="0,0,0,10" Foreground="#333333"/>
                        <CheckBox x:Name="ChkShowRepeatLabel" Content="显示循环标记（日/月/年等，位于序号后方小圆点内）" Margin="0,0,0,10" Foreground="#333333"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="置顶序号排序：" FontSize="12" Foreground="#333333" VerticalAlignment="Center" Width="90"/>
                            <ComboBox x:Name="CmbPinnedNumberMode" Width="150" FontSize="12" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="统一排序" Tag="Unified"/>
                                <ComboBoxItem Content="单独排序" Tag="Separate"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="统一排序：置顶与非置顶任务使用连续序号&#x0a;单独排序：置顶和非置顶任务各自独立编号" FontSize="10" Foreground="#999999" Margin="0,-6,0,10" TextWrapping="Wrap"/>

                        <Separator Margin="0,8,0,16"/>

                        <TextBlock Text="启动设置" FontWeight="SemiBold" FontSize="14" Foreground="#333333" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ChkAutoStart" Content="开机自启动" Margin="0,0,0,10" Foreground="#333333"/>

                        <Separator Margin="0,8,0,16"/>

                        <TextBlock Text="窗口设置" FontWeight="SemiBold" FontSize="14" Foreground="#333333" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ChkWallpaperMode" Content="桌面模式（显示在图标之上、窗口之下）" Margin="0,0,0,10" Foreground="#333333"/>
                        <CheckBox x:Name="ChkEdgeHide" Content="隐私隐藏（拖到屏幕边缘自动隐藏 + Ctrl+H 快捷键）" Margin="0,0,0,10" Foreground="#333333"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="取消" Width="80" Height="32" Margin="0,0,10,0" 
                    Click="BtnCancel_Click" FontSize="13"
                    Background="#F5F5F5" Foreground="#666666" BorderBrush="#E0E0E0" BorderThickness="1"/>
            <Button x:Name="BtnOK" Content="确定" Width="80" Height="32" 
                    Click="BtnOK_Click" FontSize="13"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
